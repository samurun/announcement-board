# Copy to `.env` and fill in values: `cp .env.example .env`

# Database (Postgres service in docker-compose)
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Used by Prisma CLI and apps/api at runtime.
# When api runs outside Docker (local `pnpm dev`), use localhost.
# When api runs inside the compose network, compose overrides this to `db:5432`.
DATABASE_URL=

# API server
API_PORT=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=

# Web
WEB_PORT=
VITE_API_URL=

# CORS (must match the frontend origin)
CORS_ORIGIN=
